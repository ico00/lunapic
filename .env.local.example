# Optional — free OpenSky Network account (https://opensky-network.org/) improves API rate limits vs. anonymous.
# Do not use NEXT_PUBLIC_*; these stay server-side only. No paid tier required for basic registration.
# OPENSKY_API_USER=
# OPENSKY_API_PASSWORD=
# Optional — server-side: upstream OpenSky budget (TTFB + body) in ms, 2000–9600; default 9200. Vercel Hobby max ~10s per function. vercel.json + preferredRegion use fra1 (EU).
# OPENSKY_UPSTREAM_TIMEOUT_MS=9200
# Optional — set to 0 for a smaller/faster OpenSky JSON (no ADS-B category / extended state vector). Helps if you still see proxy timeouts.
# OPENSKY_STATES_EXTENDED=0
# Set to 1 to show in-map field performance overlay (see documentation/performance.md)
# NEXT_PUBLIC_FIELD_PERF=
# Optional — ADS-B One: set to 1 to skip browser→api.adsb.one direct fetch (proxy only). Rarely needed.
# NEXT_PUBLIC_ADSBONE_DISABLE_DIRECT=1
# Public canonical base URL for SEO metadata, robots, and sitemap.
# Include full public app URL (with subpath if deployed under one), e.g. https://example.com/LunaPic
# NEXT_PUBLIC_SITE_URL=
# OpenAIP — VFR raster overlay tiles. Besplatni account na https://www.openaip.net/ → profile → API key.
# Bez ovog VFR Map layer neće učitati tile-ove (gumb ostaje, mapa ostaje tamna).
# NEXT_PUBLIC_OPENAIP_API_KEY=
